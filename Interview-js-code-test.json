Grouping an array of objects by a property
-----------------------------------------------
var people = [
{ name: 'Alice', age: 21 },
{ name: 'Max', age: 20 },
{ name: 'Jane', age: 20 },
{ name: 'siva', age: 23 },
{ name: 'jaga', age: 24 },
{ name: 'mani', age: 25 },
];

Expected Output:
{
  20: [
    { name: 'Max', age: 20 },
    { name: 'Jane', age: 20 }
  ],
  21: [
    { name: 'Alice', age: 21 }
  ],
  23: [
    { name: 'siva', age: 23 }
  ],
  24: [
    { name: 'jaga', age: 24 }
  ],
  25: [
    { name: 'mani', age: 25 }
  ]
}

const result = Object.groupBy(people, person => person.age);
console.log({...result});

// Using reduce method
const groupBy = (arr, prop) =>
  arr.reduce((acc, obj) => {
    (acc[obj[prop]] ??= []).push(obj);
    return acc;
  }, {});
  
console.log(groupBy(people, 'age'));

